# Supabase — V2 keys (since 2026-05-16; legacy JWT anon/service_role keys deprecated)
# 브라우저 노출 OK (publishable). Vite가 import.meta.env로 빌드 시 주입.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# 서버 only — Cloudflare Workers Secrets / Supabase Edge Function Secrets로 주입.
# VITE_ 접두사 없음 → 브라우저 번들에 들어가지 않음. 절대 commit 금지.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Kakao Developers JavaScript 키 (developers.kakao.com → 앱 설정 → 앱 키).
# 카카오톡 공유 (Kakao.Share.sendDefault) 활성화에 필요. 값 없거나 PLACEHOLDER면
# shareToKakao()는 URL 클립보드 복사로 fallback.
VITE_KAKAO_JS_KEY=
